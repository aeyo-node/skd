# .gcloudignore
# Prevent local build files, dependencies, and git history from uploading to GCP Cloud Build

.gcloudignore
.git
.gitignore

# Node.js
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment and secrets (secrets must be mapped in GCP Console)
.env*.local
.env

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
